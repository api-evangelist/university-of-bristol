{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/university-of-bristol/main/json-schema/university-of-bristol-dataset-schema.json",
  "title": "DataSet",
  "description": "A research dataset record from the University of Bristol Research Portal (Pure API 5.34.1).",
  "type": "object",
  "required": ["title", "type", "managingOrganization", "publisher", "persons", "visibility"],
  "properties": {
    "pureId": { "type": "integer" },
    "uuid": { "type": "string", "format": "uuid" },
    "createdBy": { "type": "string" },
    "createdDate": { "type": "string", "format": "date-time" },
    "modifiedBy": { "type": "string" },
    "modifiedDate": { "type": "string", "format": "date-time" },
    "portalUrl": { "type": "string", "format": "uri" },
    "version": { "type": "string" },
    "title": { "type": "object", "additionalProperties": true },
    "type": { "$ref": "#/$defs/ClassificationRef" },
    "license": { "$ref": "#/$defs/ClassificationRef" },
    "totalNumberOfAuthors": { "type": "integer" },
    "openAireCompliant": { "type": "boolean" },
    "systemName": { "type": "string" }
  },
  "$defs": {
    "ClassificationRef": {
      "type": "object",
      "required": ["uri"],
      "properties": {
        "uri": { "type": "string" },
        "term": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
